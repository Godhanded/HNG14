# Copy this file to .env and fill in your real values.
# .env is loaded automatically by Docker Compose.

# Your VPS public IP address (used by Nextcloud to trust incoming requests)
VPS_IP=YOUR_VPS_IP_HERE

# MariaDB passwords — change these before deploying
DB_ROOT_PASSWORD=changeme_root
DB_PASSWORD=changeme_user

# Slack Incoming Webhook URL for alerts
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
